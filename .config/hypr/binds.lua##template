-- Workspace switching & moving windows
{% if yadm.class == "laptop" %}
for i = 1, 5 do
    hl.bind(mainMod .. " + " .. i,          hl.dsp.focus({ workspace = i }))
    hl.bind(mainMod .. " + SHIFT + " .. i,  hl.dsp.window.move({ workspace = i }))
end
{% else %}
for i = 1, 5 do
    hl.bind(mainMod .. " + " .. i, function()
        local mon = hl.get_active_monitor()
        local ws = mon.id * 5 + i
        hl.dispatch(hl.dsp.focus({ workspace = ws }))
    end)
    hl.bind(mainMod .. " + SHIFT + " .. i, function()
        local mon = hl.get_active_monitor()
        local ws = mon.id * 5 + i
        hl.dispatch(hl.dsp.window.move({ workspace = ws }))
    end)
end

for i = 1, 5 do
    hl.workspace_rule({ workspace = i, monitor = "DP-2" })
end
for i = 6, 10 do
    hl.workspace_rule({ workspace = i, monitor = "DP-3" })
end
{% endif %}

