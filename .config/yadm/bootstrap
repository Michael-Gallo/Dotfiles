#!/bin/bash

set -euo pipefail
if [ "$EUID" -eq 0 ]; then
  echo "Do not run this script as root."
  exit 1
fi

package_list_path=$XDG_CONFIG_HOME/yadm/packages.txt
script_dir=$(dirname "$(readlink -f "$0")")

if [ ! -f "$package_list_path" ]; then
  echo "$package_list_path not found"
  exit 1
fi

flatpak_list_path=$XDG_CONFIG_HOME/yadm/flatpaks.txt

if [ ! -f "$flatpak_list_path" ]; then
  echo "$flatpak_list_path not found"
  exit 1
fi

wallpaper_location=$XDG_PICTURES_DIR/wallpapers
# Ensure that wallpaper is set
if [ ! -f "$wallpaper_location/wallpaper" ]; then
  echo "setting wallpaper"
  mkdir -p "$wallpaper_location"
  cp "$XDG_CONFIG_HOME/yadm/wallpaper.png" "$wallpaper_location/wallpaper"
fi

sudo pacman -S --noconfirm --needed git base-devel 

install_paru(){
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT INT TERM
    git clone https://aur.archlinux.org/paru.git "$tmpdir/paru"
    cd "$tmpdir/paru"
    makepkg -si --noconfirm
}
# Install Paru
if ! command -v paru >/dev/null 2>&1; then
    echo "Installing Paru AUR helper"
    (install_paru)
fi

echo "Updating system"
paru -Syu --noconfirm
echo "Installing needed packages"
paru -S --noconfirm --needed --quiet $(< "$package_list_path") 2>&1 | grep -vi warning:

echo "Installing needed flatpaks"
flatpak install -y $(< "$flatpak_list_path") 2>&1 | grep -vi warning:

# Override for Discord so link opening works
flatpak override --user com.discordapp.Discord \
  --talk-name=org.freedesktop.portal.Desktop \
  --talk-name=org.freedesktop.portal.Documents

echo "Installing nvim plugins"
nvim --headless -c 'Lazy sync' -c 'qa'

echo "Setting groups"

sudo usermod -a -G storage $USER
sudo usermod -a -G scanner $USER
sudo usermod -a -G docker $USER


git config --global pull.rebase true
git config --global rerere.enabled true

gitlab_url="git@gitlab.com:michaelagallo95/dotfiles.git"
github_url="git@github.com:Michael-Gallo/Dotfiles.git"
remote_name="origin"
current_origin_url=$(yadm remote get-url "$remote_name" 2>/dev/null || echo "")

if [ "$current_origin_url" != "$github_url" ]; then
    echo "Setting GitHub/GitLab remote structure"
    yadm remote remove $remote_name 2>/dev/null || true
    yadm remote add $remote_name $github_url
    yadm fetch --all
    current_branch=$(yadm symbolic-ref --short HEAD)
    yadm branch --set-upstream-to="$remote_name/$current_branch" "$current_branch"
    yadm remote set-url --add --push $remote_name $gitlab_url
    yadm remote set-url --add --push $remote_name $github_url
fi


if [ -d /sys/class/power_supply/BAT* ] 2>/dev/null; then
    echo "Setting laptop class"
    yadm config local.class laptop

fi

yadm alt
# Needed for previews
mkdir -p $HOME/.cache/lf/thumbnail

# Have fish set universal variables
fish $HOME/.config/fish/fish_setup.fish
# Write files

write_if_different() {
  local content="$1"
  local target_file="$2"
  local tmp_file="${target_file}.tmp"

  # Write content to a temporary file with sudo
  echo "$content" | sudo tee "$tmp_file" >/dev/null

  # Compare temporary file with target file
  echo "comparing file $target_file to $tmp_file"
  if ! sudo cmp -s "$target_file" "$tmp_file"; then
    # Replace target file only if different
    sudo mv "$tmp_file" "$target_file"
    echo "Updated $target_file"
  else
    # Remove temporary file if no difference
    sudo rm "$tmp_file"
  fi
}

# Disable the annoying pcspkr module/beep sound
write_if_different "blacklist pcspkr"  /etc/modprobe.d/nobeep.conf
write_if_different "[default_session]
command = \"Hyprland\"
user=\"$USER\" " /etc/greetd/tuigreet.toml
# make it take 10 retries to lock me out
faillock_file="$script_dir/faillock.conf"
write_if_different "$(cat "$faillock_file")" /etc/security/faillock.conf



# Enable services
services=(avahi-daemon cups jellyfin)

for svc in "${services[@]}"; do
  sudo systemctl enable "$svc.service" --now
done

# Set up Rclone config
"$script_dir/set_rclone.sh"
